{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tobiasosborne/quantum-hardware/schema/device.schema.json",
  "title": "Quantum Device Revision",
  "description": "One revision of one quantum computing device. See schema/SCHEMA.md for prose.",
  "type": "object",
  "required": ["meta", "organization", "family", "device", "topology", "native_gates", "noise_model", "timing", "access", "provenance"],
  "additionalProperties": false,

  "$defs": {
    "modality": {
      "enum": [
        "sc_transmon", "sc_fluxonium", "sc_cat", "sc_dual_rail",
        "trapped_ion", "neutral_atom",
        "photonic_discrete", "photonic_cv",
        "si_spin", "ge_spin",
        "nv_diamond", "sic_defect",
        "topological_majorana",
        "nmr",
        "annealer_dwave", "annealer_parametron",
        "molecular", "rare_earth_cavity"
      ]
    },
    "status": {
      "enum": ["projected", "announced", "under_construction", "in_service", "intermittent", "decommissioned", "retired"]
    },
    "topology_kind": {
      "enum": ["all_to_all", "heavy_hex", "square_grid", "hex", "linear_chain", "ring", "kagome", "bipartite", "reconfigurable", "analog_hamiltonian", "custom"]
    },
    "org_kind": {
      "enum": ["commercial", "academic", "national_lab", "consortium", "government"]
    },
    "source_kind": {
      "enum": ["paper_arxiv", "paper_doi", "press_release", "vendor_doc", "api_dump", "talk_video", "datasheet", "book_report", "conference_abstract", "blog_post", "forum_post", "wikipedia"]
    },
    "api_kind": {
      "enum": ["qiskit_runtime", "braket", "azure_quantum", "qcs", "pulser", "bloqade", "strawberry_fields", "ionq_rest", "pasqal_core", "openqasm3", "openpulse", "custom", "offline"]
    },
    "cloud_provider": {
      "enum": ["aws_braket", "azure_quantum", "ibm_quantum", "google_quantum_ai", "ionq_cloud", "pasqal_cloud", "xanadu_cloud", "rigetti_qcs", "oqc_cloud", "quantinuum_systems", "dwave_leap", "origin_cloud", "tianyan", "juniq", "nqcc", "none"]
    },
    "access_tier": {
      "enum": ["open", "free", "paid", "research_only", "private", "not_accessible"]
    },
    "t2_kind": {
      "enum": ["ramsey", "echo", "cpmg"]
    },
    "native_gate_kind": {
      "enum": ["gate", "measurement", "reset", "idle", "analog_hamiltonian"]
    },
    "logical_code": {
      "enum": ["steane", "surface", "rotated_surface", "bivariate_bicycle", "color", "gkp", "cat", "dual_rail_cavity", "repetition", "shor", "custom"]
    }
  },

  "properties": {
    "meta": {
      "type": "object",
      "required": ["id", "org_slug", "schema_version", "created_at", "updated_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
        "org_slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_]*[a-z0-9]$" },
        "aliases": { "type": "array", "items": { "type": "string" } },
        "schema_version": { "type": "string", "enum": ["0.1"] },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    },
    "organization": {
      "type": "object",
      "required": ["name", "kind", "country"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "kind": { "$ref": "#/$defs/org_kind" },
        "country": { "type": "string", "pattern": "^[A-Z]{3}$" },
        "parent": { "type": "string" },
        "homepage_url": { "type": "string", "format": "uri" }
      }
    },
    "family": {
      "type": "object",
      "required": ["name", "modality"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "modality": { "$ref": "#/$defs/modality" },
        "lineage_predecessor": { "type": "string" }
      }
    },
    "device": {
      "type": "object",
      "required": ["name", "status", "num_qubits"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "status": { "$ref": "#/$defs/status" },
        "announced_date": { "type": "string", "format": "date" },
        "first_operational_date": { "type": "string", "format": "date" },
        "decommissioned_date": { "type": "string", "format": "date" },
        "num_qubits": { "type": "integer", "minimum": 0 },
        "num_logical": { "type": "integer", "minimum": 0 },
        "logical_code": { "$ref": "#/$defs/logical_code" },
        "code_distance": { "type": "integer", "minimum": 1 },
        "architecture_notes": { "type": "string" }
      }
    },
    "topology": {
      "type": "object",
      "required": ["kind", "reconfigurable"],
      "additionalProperties": false,
      "properties": {
        "kind": { "$ref": "#/$defs/topology_kind" },
        "reconfigurable": { "type": "boolean" },
        "coupling_map": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "integer", "minimum": 0 },
            "minItems": 2,
            "maxItems": 2
          }
        },
        "position_constraints": {
          "type": "object",
          "additionalProperties": true
        },
        "diagram_url": { "type": "string", "format": "uri" }
      }
    },
    "native_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "arity", "kind"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "arity": { "type": "integer", "minimum": 1 },
          "kind": { "$ref": "#/$defs/native_gate_kind" },
          "params": { "type": "array", "items": { "type": "string" } },
          "duration_ns": { "type": "number", "minimum": 0 },
          "fidelity_mean": { "type": "number", "minimum": 0, "maximum": 1 },
          "fidelity_median": { "type": "number", "minimum": 0, "maximum": 1 },
          "fidelity_per_qubit": {
            "type": "array",
            "items": { "type": ["number", "null"] }
          },
          "fidelity_per_pair": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["pair", "fidelity"],
              "properties": {
                "pair": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "fidelity": { "type": "number", "minimum": 0, "maximum": 1 }
              }
            }
          },
          "kraus_operators_file": { "type": "string" },
          "ptm_file": { "type": "string" }
        }
      }
    },
    "noise_model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "t1_us": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mean": { "type": "number", "minimum": 0 },
            "median": { "type": "number", "minimum": 0 },
            "per_qubit": {
              "type": "array",
              "items": { "type": ["number", "null"] }
            }
          }
        },
        "t2_us": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "$ref": "#/$defs/t2_kind" },
            "mean": { "type": "number", "minimum": 0 },
            "median": { "type": "number", "minimum": 0 },
            "per_qubit": {
              "type": "array",
              "items": { "type": ["number", "null"] }
            }
          }
        },
        "readout": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "fidelity_mean": { "type": "number", "minimum": 0, "maximum": 1 },
            "fidelity_per_qubit": {
              "type": "array",
              "items": { "type": ["number", "null"] }
            },
            "confusion_matrix_file": { "type": "string" }
          }
        },
        "crosstalk": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "calibration_snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["timestamp", "raw_file", "provenance_idx"],
        "additionalProperties": false,
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "t1_us_mean": { "type": "number", "minimum": 0 },
          "t2_us_mean": { "type": "number", "minimum": 0 },
          "gate_err_1q_mean": { "type": "number", "minimum": 0, "maximum": 1 },
          "gate_err_2q_mean": { "type": "number", "minimum": 0, "maximum": 1 },
          "readout_err_mean": { "type": "number", "minimum": 0, "maximum": 1 },
          "raw_file": { "type": "string" },
          "provenance_idx": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "timing": {
      "type": "object",
      "required": ["single_qubit_gate_ns", "two_qubit_gate_ns", "readout_ns"],
      "additionalProperties": false,
      "properties": {
        "single_qubit_gate_ns": { "type": "number", "minimum": 0 },
        "two_qubit_gate_ns": { "type": "number", "minimum": 0 },
        "readout_ns": { "type": "number", "minimum": 0 },
        "reset_ns": { "type": "number", "minimum": 0 },
        "shot_rate_hz": { "type": "number", "minimum": 0 },
        "queue_depth_notes": { "type": "string" }
      }
    },
    "access": {
      "type": "object",
      "required": ["api_kind", "tier", "auth_required"],
      "additionalProperties": false,
      "properties": {
        "cloud_provider": { "$ref": "#/$defs/cloud_provider" },
        "api_kind": { "$ref": "#/$defs/api_kind" },
        "api_endpoint": { "type": "string", "format": "uri" },
        "tier": { "$ref": "#/$defs/access_tier" },
        "auth_required": { "type": "boolean" },
        "pricing_notes": { "type": "string" },
        "sdk_packages": { "type": "array", "items": { "type": "string" } }
      }
    },
    "benchmarks": {
      "type": "object",
      "additionalProperties": true
    },
    "energy_carbon": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fridge_kw": { "type": "number", "minimum": 0 },
        "system_kw": { "type": "number", "minimum": 0 },
        "per_shot_j": { "type": "number", "minimum": 0 },
        "kgco2_per_shot": { "type": "number", "minimum": 0 },
        "cooling_notes": { "type": "string" },
        "helium3_notes": { "type": "string" }
      }
    },
    "roadmap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "originally_targeted_year": { "type": "integer", "minimum": 1980, "maximum": 2100 },
        "originally_targeted_qubits": { "type": "integer", "minimum": 0 },
        "originally_targeted_logical": { "type": "integer", "minimum": 0 },
        "originally_targeted_fidelity_1q": { "type": "number", "minimum": 0, "maximum": 1 },
        "originally_targeted_fidelity_2q": { "type": "number", "minimum": 0, "maximum": 1 },
        "narrative": { "type": "string" }
      }
    },
    "provenance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["field_path", "value", "source_url", "source_kind", "retrieved_at", "local_path", "sha256"],
        "additionalProperties": false,
        "properties": {
          "field_path": { "type": "string" },
          "value": {},
          "source_url": { "type": "string", "format": "uri" },
          "source_kind": { "$ref": "#/$defs/source_kind" },
          "retrieved_at": { "type": "string", "format": "date-time" },
          "local_path": { "type": "string", "pattern": "^sources/[0-9]{4}/[0-9]{2}/[0-9]{2}/" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "notes": { "type": "string" },
          "conflict": { "type": "boolean" }
        }
      }
    }
  }
}
